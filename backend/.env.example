# 서버 전용 설정 — 실제 값은 .env 에만 (커밋 금지, .gitignore 처리됨)
# 사용법: cp backend/.env.example backend/.env 후 값 채우기

# Upstage Solar API 키 (팀 소유, 서버에서만 사용 — 프론트 노출 절대 금지)
SOLAR_API_KEY=up_xxxxxxxxxxxxxxxxxxxx

# Solar API 엔드포인트/모델 (OpenAI 호환, 2026-07 공식문서 확인)
# base_url + /chat/completions, 최신 모델 = solar-pro3 (102B MoE)
SOLAR_BASE_URL=https://api.upstage.ai/v1
SOLAR_MODEL=solar-pro3

# 캐시 경로 (크롤러 산출물). 기본값은 ../crawler/cache
# CACHE_DIR=../crawler/cache

# Neon connection string. 공개 저장소라 캐시를 커밋 안 하므로, 배포 백엔드가
# 부팅 시 cache_blobs 테이블에서 캐시를 받아온다. upload_cache.py 실행 때도 사용.
# (로컬은 crawler/cache/*.json 이 이미 있으면 없어도 동작)
# DATABASE_URL=postgresql://...neon...?sslmode=require

# CORS 허용 오리진 (배포 시 필수). 프론트 도메인을 쉼표로 나열.
# 미지정 시 로컬 개발 오리진(localhost:3000/3100)만 허용.
# 예) ALLOWED_ORIGINS=https://syllafit.vercel.app,https://www.syllafit.app
# ALLOWED_ORIGINS=https://your-frontend.vercel.app
